# =============================================================================
# AI Code Reviewer — Конфигурация
# =============================================================================
# Скопируйте этот файл в .env и заполните своими значениями
# cp .env.example .env

# ---------------------------------------------------------------------------
# Qdrant (векторная база данных)
# ---------------------------------------------------------------------------
QDRANT_URL=http://localhost:6333

# ---------------------------------------------------------------------------
# Ollama (локальные модели)
# ---------------------------------------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text-v2-moe
OLLAMA_LLM_MODEL=qwen2.5-coder:7b

# ---------------------------------------------------------------------------
# GigaChat (облачный LLM — опционально)
# ---------------------------------------------------------------------------
# true  = использовать GigaChat через OpenAI-совместимый API
# false = использовать локальную Ollama
USE_GIGACHAT=false
GIGACHAT_CLIENT_ID=your-client-id
GIGACHAT_CLIENT_SECRET=your-client-secret

# ---------------------------------------------------------------------------
# GitHub API
# ---------------------------------------------------------------------------
GITHUB_TOKEN=ghp_your-token-here
GITHUB_OWNER=your-username-or-org
GITHUB_REPO=test-repo-for-ai-reviewer

# true  = работать с реальным GitHub API
# false = использовать мок-дифф для тестов
USE_REAL_GITHUB_API=false
