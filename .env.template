# =============================================================================
# AI Code Reviewer — Конфигурация
# =============================================================================
# Скопируйте этот файл в .env и заполните своими значениями
# cp .env.example .env

# ---------------------------------------------------------------------------
# OpenAI (облачный провайдер LLM и эмбеддингов)
# ---------------------------------------------------------------------------
# Используется, когда USE_LOCAL_MODELS=false
# Получить ключ: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# ---------------------------------------------------------------------------
# Qdrant (векторная база данных)
# ---------------------------------------------------------------------------
# Docker: docker compose up -d qdrant
QDRANT_URL=http://localhost:6333

# ---------------------------------------------------------------------------
# Ollama (локальные модели — эмбеддинги и LLM)
# ---------------------------------------------------------------------------
# Docker: docker compose up -d ollama
OLLAMA_BASE_URL=http://localhost:11434

# Модель эмбеддингов (загружается в ollama-pull)
# Варианты: nomic-embed-text-v2-moe, nomic-embed-text, evilfreelancer/enbeddrus
OLLAMA_EMBED_MODEL=nomic-embed-text-v2-moe

# Модель LLM (загружается в ollama-pull)
# Варианты: llama3.2, qwen2.5:7b, mistral, gemma3
OLLAMA_LLM_MODEL=llama3.2

# ---------------------------------------------------------------------------
# GitHub API (для интеграции с пул-реквестами)
# ---------------------------------------------------------------------------
# Получить токен: GitHub → Settings → Developer settings → Personal access tokens
# Права: repo (для приватных) или public_repo (для публичных)
GITHUB_TOKEN=ghp_your-token-here
GITHUB_OWNER=your-username-or-org
GITHUB_REPO=test-repo-for-ai-reviewer

# ---------------------------------------------------------------------------
# Режимы работы
# ---------------------------------------------------------------------------
# true  = использовать локальные модели Ollama (эмбеддинги и LLM)
# false = использовать облачные модели OpenAI (требуется OPENAI_API_KEY)
USE_LOCAL_MODELS=false

# true  = работать с реальным GitHub API (требуется GITHUB_TOKEN)
# false = использовать мок-сервер для тестов
USE_REAL_GITHUB_API=false
# Модель эмбеддингов (загружается в ollama-pull)
OLLAMA_EMBED_MODEL=nomic-embed-text-v2-moe

# Модель LLM (загружается в ollama-pull)
OLLAMA_LLM_MODEL=qwen2.5:7b
